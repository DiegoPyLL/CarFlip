# ── Base de datos ────────────────────────────────────────────────────────────
# Local: PostgreSQL local
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/carflipper
# Supabase (producción): usar Transaction Pooler, puerto 6543
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?ssl=require

# ── Credenciales de sitios (solo en modo local, USE_SECRETS_MANAGER=false) ───
# Generar clave Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=

# ── MercadoLibre API (https://developers.mercadolibre.cl) ────────────────────
MERCADOLIBRE_APP_ID=
MERCADOLIBRE_CLIENT_SECRET=

# ── Scheduler ────────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6

# ── Anti-detección ───────────────────────────────────────────────────────────
MIN_DELAY_SECONDS=2
MAX_DELAY_SECONDS=6

# ── Alertas ──────────────────────────────────────────────────────────────────
DEAL_THRESHOLD_PCT=15

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/carflipper.log

# ── AWS (solo en modo cloud, USE_SECRETS_MANAGER=true) ───────────────────────
USE_SECRETS_MANAGER=false
AWS_REGION=us-east-1
SECRETS_MANAGER_PREFIX=carflipper/prod
