---
import type { FiltrosAviso, FiltrosDisponibles } from '@lib/tipos';

interface Props {
  filtros: FiltrosAviso;
  disponibles: FiltrosDisponibles;
}

const { filtros, disponibles } = Astro.props;

const inputCls = [
  'w-full text-sm',
  'bg-zinc-800 border border-zinc-700/80 rounded-lg px-3 py-1.5',
  'text-zinc-200 placeholder-zinc-600',
  'focus:outline-none focus:ring-1 focus:ring-amber-400/50 focus:border-amber-400/50',
  'transition-colors',
].join(' ');

const selectCls = [
  'w-full text-sm',
  'bg-zinc-800 border border-zinc-700/80 rounded-lg px-3 py-1.5',
  'text-zinc-200 appearance-none cursor-pointer',
  'focus:outline-none focus:ring-1 focus:ring-amber-400/50 focus:border-amber-400/50',
  'transition-colors',
].join(' ');

const labelCls = 'text-[10px] font-semibold text-zinc-600 uppercase tracking-wider block mb-1';

const hayFiltrosAvanzados = !!(
  filtros.modelo ||
  filtros.combustible ||
  filtros.km_max ||
  filtros.precio_min ||
  filtros.precio_max
);
---

<!-- Botón toggle (solo visible en mobile) -->
<div class="lg:hidden mb-3">
  <button
    type="button"
    id="sidebar-toggle"
    class="flex items-center gap-2 text-xs font-semibold text-zinc-500 hover:text-zinc-300 transition-colors py-1"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 6h18M7 12h10M10 18h4"/>
    </svg>
    <span id="toggle-label">
      {hayFiltrosAvanzados ? 'Filtros avanzados activos' : 'Más filtros'}
    </span>
    {hayFiltrosAvanzados && (
      <span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block shrink-0" />
    )}
  </button>
</div>

<!--
  Panel: hidden en mobile por defecto, siempre visible en desktop (lg:block).
  Un único set de inputs → sin duplicados al submitear el form.
-->
<aside
  id="filtros-sidebar"
  class="hidden lg:block w-full lg:w-48 lg:shrink-0 lg:sticky lg:top-20 lg:self-start"
>
  <div class="bg-zinc-900 rounded-xl border border-zinc-800/60 p-4 space-y-3.5">
    <p class="text-[10px] font-semibold text-zinc-600 uppercase tracking-wider hidden lg:block">
      Filtros avanzados
    </p>

    <!-- Buscar (titulo + marca + modelo) -->
    <div>
      <label for="modelo" class={labelCls}>Buscar</label>
      <input
        id="modelo"
        type="text"
        name="modelo"
        value={filtros.modelo ?? ''}
        placeholder="Jeep, Corolla, Civic…"
        maxlength="100"
        class={inputCls}
      />
    </div>

    <!-- Combustible -->
    <div>
      <label for="combustible" class={labelCls}>Combustible</label>
      <select id="combustible" name="combustible" class={selectCls}>
        <option value="">Todos</option>
        {disponibles.combustibles.map((c) => (
          <option value={c} selected={filtros.combustible === c}>{c}</option>
        ))}
      </select>
    </div>

    <!-- Km máximo -->
    <div>
      <label for="km_max" class={labelCls}>Km máximo</label>
      <input
        id="km_max"
        type="number"
        name="km_max"
        min="0"
        step="any"
        value={filtros.km_max ?? ''}
        placeholder="Sin límite"
        class={inputCls}
      />
    </div>

    <!-- Precio mínimo -->
    <div>
      <label for="precio_min" class={labelCls}>Precio mínimo</label>
      <input
        id="precio_min"
        type="number"
        name="precio_min"
        min="0"
        step="any"
        value={filtros.precio_min ?? ''}
        placeholder="$ 0"
        class={inputCls}
      />
    </div>

    <!-- Precio máximo -->
    <div>
      <label for="precio_max" class={labelCls}>Precio máximo</label>
      <input
        id="precio_max"
        type="number"
        name="precio_max"
        min="0"
        step="any"
        value={filtros.precio_max ?? ''}
        placeholder="Sin límite"
        class={inputCls}
      />
    </div>

    <button
      type="submit"
      class="w-full bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-300 text-xs font-semibold py-2 rounded-lg transition-colors mt-1"
    >
      Aplicar filtros
    </button>
  </div>
</aside>

<script>
  const btn   = document.getElementById('sidebar-toggle');
  const panel = document.getElementById('filtros-sidebar');
  const label = document.getElementById('toggle-label');

  btn?.addEventListener('click', () => {
    const hidden = panel?.classList.contains('hidden') ?? true;
    panel?.classList.toggle('hidden', !hidden);
    if (label) label.textContent = hidden ? 'Ocultar filtros' : 'Más filtros';
  });
</script>
