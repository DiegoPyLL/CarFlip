---
import type { FiltrosAviso, FiltrosDisponibles } from '@lib/tipos';

interface Props {
  filtros: FiltrosAviso;
  disponibles: FiltrosDisponibles;
}

const { filtros, disponibles } = Astro.props;

const fuentes = [
  { value: '', label: 'Todas' },
  { value: 'autocosmos', label: 'Autocosmos' },
  { value: 'yapo', label: 'Yapo' },
];

const selectCls = [
  'text-sm bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-1.5',
  'text-zinc-200 appearance-none cursor-pointer',
  'focus:outline-none focus:ring-1 focus:ring-amber-400/50 focus:border-amber-400/50',
  'transition-colors',
].join(' ');
---

<div class="flex flex-wrap items-end gap-3 pb-5 mb-5 border-b border-zinc-800/60">

  <!-- Fuente: toggle buttons -->
  <div>
    <p class="text-[10px] font-semibold text-zinc-600 uppercase tracking-wider mb-1.5">Fuente</p>
    <div class="flex gap-1">
      {fuentes.map(({ value, label }) => (
        <label class="cursor-pointer select-none">
          <input
            type="radio"
            name="fuente"
            value={value}
            class="sr-only peer"
            checked={filtros.fuente === value || (!filtros.fuente && value === '')}
          />
          <span class="inline-block px-3 py-1.5 text-xs font-semibold rounded-lg border border-zinc-700 text-zinc-500 peer-checked:bg-amber-400 peer-checked:text-zinc-900 peer-checked:border-amber-400 hover:border-zinc-500 hover:text-zinc-300 transition-all">
            {label}
          </span>
        </label>
      ))}
    </div>
  </div>

  <!-- Marca -->
  <div class="flex flex-col gap-1">
    <label for="marca" class="text-[10px] font-semibold text-zinc-600 uppercase tracking-wider">Marca</label>
    <select id="marca" name="marca" class={selectCls}>
      <option value="">Todas</option>
      {disponibles.marcas.map((m) => (
        <option value={m} selected={filtros.marca === m}>{m}</option>
      ))}
    </select>
  </div>

  <!-- Año -->
  <div class="flex flex-col gap-1">
    <label for="anio" class="text-[10px] font-semibold text-zinc-600 uppercase tracking-wider">Año</label>
    <select id="anio" name="anio" class={selectCls}>
      <option value="">Todos</option>
      {disponibles.anios.map((a) => (
        <option value={a} selected={filtros.anio === a}>{a}</option>
      ))}
    </select>
  </div>

  <!-- Spacer -->
  <div class="hidden lg:flex flex-1" />

  <!-- Acciones -->
  <div class="flex items-end gap-2 ml-auto lg:ml-0">
    <button
      type="submit"
      class="bg-amber-400 hover:bg-amber-300 text-zinc-900 text-sm font-semibold px-5 py-1.5 rounded-lg transition-colors duration-150"
    >
      Filtrar
    </button>
    <a
      href="/"
      class="text-sm text-zinc-600 hover:text-zinc-300 transition-colors py-1.5"
    >
      Limpiar
    </a>
  </div>
</div>
