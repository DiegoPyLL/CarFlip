---
import type { Aviso } from '@lib/tipos';
import { resolverUrlImagen } from '@lib/cdn';
import { formatearPrecio, formatearKm, signosDelta } from '@lib/formato';

interface Props {
  aviso: Aviso;
}

const { aviso } = Astro.props;
const urlImagen = resolverUrlImagen(aviso.url_imagen);
const delta = signosDelta(aviso.delta_pct);

const fuenteLabel = aviso.fuente === 'autocosmos' ? 'Autocosmos' : 'Yapo';

const metaItems = [
  aviso.anio ? String(aviso.anio) : null,
  formatearKm(aviso.km) !== '—' ? formatearKm(aviso.km) : null,
  aviso.ubicacion ?? null,
].filter(Boolean);
---

<article class="group bg-zinc-900 rounded-xl overflow-hidden border border-zinc-800/50 hover:border-zinc-700 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-zinc-950/60">
  <a
    href={`/auto/${aviso.id}?back=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`}
    aria-label={`Ver ${aviso.titulo}`}
    class="block"
  >
    <!-- Imagen -->
    <div class="aspect-[4/3] bg-zinc-800 relative overflow-hidden">
      {urlImagen ? (
        <img
          src={urlImagen}
          alt={aviso.titulo}
          width={400}
          height={300}
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300 ease-out"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center">
          <span class="text-zinc-700 text-xs">Sin imagen</span>
        </div>
      )}

      <!-- Badges sobre la imagen -->
      <div class="absolute top-2.5 left-2.5 flex gap-1.5">
        <span class="text-[10px] font-semibold px-2 py-0.5 rounded bg-zinc-950/75 text-zinc-300 backdrop-blur-sm">
          {fuenteLabel}
        </span>
        {delta && (
          <span class={`text-[10px] font-semibold px-2 py-0.5 rounded backdrop-blur-sm ${delta.clases}`}>
            {delta.texto}
          </span>
        )}
        {aviso.disponible === false && (
          <span class="text-[10px] font-semibold px-2 py-0.5 rounded bg-red-950/80 text-red-400 backdrop-blur-sm">
            No disponible
          </span>
        )}
      </div>
    </div>

    <!-- Contenido -->
    <div class="p-4">
      <h2 class="text-sm font-medium text-zinc-200 line-clamp-2 leading-snug mb-3">
        {aviso.titulo}
      </h2>

      <p class="text-xl font-bold mb-2">
        {aviso.precio
          ? <span class="text-amber-400">{formatearPrecio(aviso.precio, aviso.moneda)}</span>
          : <span class="text-zinc-600 text-sm font-normal">Precio a consultar</span>
        }
      </p>

      {metaItems.length > 0 && (
        <p class="text-xs text-zinc-600 truncate">
          {metaItems.join(' · ')}
        </p>
      )}
    </div>
  </a>
</article>
