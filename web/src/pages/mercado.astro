---
import Base from '@layouts/Base.astro';
import { obtenerDatosMercado } from '@lib/db';
import { parsearFiltrosUrl } from '@lib/filtros';
import { formatearPrecio } from '@lib/formato';

const params  = Astro.url.searchParams;
const filtros = parsearFiltrosUrl(params);
const fuente  = filtros.fuente;

const datos = await obtenerDatosMercado(fuente);

const maxMarca  = datos.marcas[0]?.total  ?? 1;
const maxModelo = datos.modelos[0]?.total ?? 1;
const maxDist   = Math.max(...datos.distribucion.map(d => d.total), 1);

const fuentes = [
  { value: '',            label: 'Todas' },
  { value: 'autocosmos',  label: 'Autocosmos' },
  { value: 'yapo',        label: 'Yapo' },
];
---

<Base
  titulo="Mercado — Estadísticas de autos en Chile"
  descripcion="Precios promedio, marcas y modelos más listados en los portales de autos en Chile."
>

  <!-- Header -->
  <div class="mb-8">
    <p class="text-xs font-semibold text-amber-400 uppercase tracking-widest mb-2">Análisis de precios</p>
    <h1 class="text-3xl font-black text-zinc-100 mb-3">Mercado</h1>
    <p class="text-sm text-zinc-500 max-w-xl">
      Estadísticas calculadas sobre {datos.total.toLocaleString('es-CL')} avisos activos.
      Se actualizan cada 6 horas junto con el resto de los datos.
    </p>
  </div>

  <!-- Filtro de fuente -->
  <form method="GET" action="/mercado" class="mb-8">
    <div class="flex items-center gap-2">
      <span class="text-[10px] font-semibold text-zinc-600 uppercase tracking-wider shrink-0">Fuente</span>
      <div class="flex gap-1">
        {fuentes.map(({ value, label }) => (
          <label class="cursor-pointer select-none">
            <input
              type="radio"
              name="fuente"
              value={value}
              class="sr-only peer"
              checked={fuente === value || (!fuente && value === '')}
              onchange="this.form.submit()"
            />
            <span class="inline-block px-3 py-1.5 text-xs font-semibold rounded-lg border border-zinc-700 text-zinc-500 peer-checked:bg-amber-400 peer-checked:text-zinc-900 peer-checked:border-amber-400 hover:border-zinc-500 hover:text-zinc-300 transition-all">
              {label}
            </span>
          </label>
        ))}
      </div>
    </div>
  </form>

  <div class="grid grid-cols-1 xl:grid-cols-[1fr_380px] gap-6">

    <!-- Columna principal -->
    <div class="space-y-6">

      <!-- Marcas más listadas -->
      <section class="bg-zinc-900 rounded-xl border border-zinc-800/60 overflow-hidden">
        <div class="px-5 py-4 border-b border-zinc-800/60">
          <h2 class="text-sm font-bold text-zinc-200">Marcas más listadas</h2>
          <p class="text-xs text-zinc-600 mt-0.5">Top 20 por cantidad de avisos</p>
        </div>
        <div class="divide-y divide-zinc-800/40">
          {datos.marcas.map((m, i) => (
            <div class="flex items-center gap-4 px-5 py-3 hover:bg-zinc-800/30 transition-colors">
              <!-- Rank -->
              <span class="text-xs font-bold text-zinc-700 w-5 shrink-0 tabular-nums text-right">
                {i + 1}
              </span>

              <!-- Nombre + barra -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between mb-1.5">
                  <a
                    href={`/?marca=${encodeURIComponent(m.marca)}`}
                    class="text-sm font-semibold text-zinc-200 hover:text-amber-400 transition-colors truncate"
                  >
                    {m.marca}
                  </a>
                  <span class="text-xs text-zinc-500 tabular-nums ml-3 shrink-0">
                    {m.total.toLocaleString('es-CL')}
                  </span>
                </div>
                <div class="h-1 bg-zinc-800 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-amber-400/70 rounded-full transition-all"
                    style={`width: ${(m.total / maxMarca * 100).toFixed(1)}%`}
                  />
                </div>
              </div>

              <!-- Precio promedio -->
              <span class="text-xs tabular-nums text-zinc-500 w-24 text-right shrink-0 hidden sm:block">
                {m.precio_promedio ? formatearPrecio(Math.round(m.precio_promedio)) : '—'}
              </span>
            </div>
          ))}
        </div>
      </section>

      <!-- Modelos más listados -->
      <section class="bg-zinc-900 rounded-xl border border-zinc-800/60 overflow-hidden">
        <div class="px-5 py-4 border-b border-zinc-800/60">
          <h2 class="text-sm font-bold text-zinc-200">Modelos más listados</h2>
          <p class="text-xs text-zinc-600 mt-0.5">Top 15 por cantidad de avisos</p>
        </div>
        <div class="divide-y divide-zinc-800/40">
          {datos.modelos.map((m, i) => (
            <div class="flex items-center gap-4 px-5 py-3 hover:bg-zinc-800/30 transition-colors">
              <span class="text-xs font-bold text-zinc-700 w-5 shrink-0 tabular-nums text-right">
                {i + 1}
              </span>

              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between mb-1.5">
                  <div class="min-w-0">
                    <a
                      href={`/?marca=${encodeURIComponent(m.marca)}&modelo=${encodeURIComponent(m.modelo)}`}
                      class="text-sm font-semibold text-zinc-200 hover:text-amber-400 transition-colors"
                    >
                      {m.modelo}
                    </a>
                    <span class="text-xs text-zinc-600 ml-2">{m.marca}</span>
                  </div>
                  <span class="text-xs text-zinc-500 tabular-nums ml-3 shrink-0">
                    {m.total.toLocaleString('es-CL')}
                  </span>
                </div>
                <div class="h-1 bg-zinc-800 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-zinc-500/60 rounded-full"
                    style={`width: ${(m.total / maxModelo * 100).toFixed(1)}%`}
                  />
                </div>
              </div>

              <span class="text-xs tabular-nums text-zinc-500 w-24 text-right shrink-0 hidden sm:block">
                {m.precio_promedio ? formatearPrecio(Math.round(m.precio_promedio)) : '—'}
              </span>
            </div>
          ))}
        </div>
      </section>

    </div>

    <!-- Columna lateral -->
    <div class="space-y-6">

      <!-- Distribución de precios -->
      <section class="bg-zinc-900 rounded-xl border border-zinc-800/60 overflow-hidden">
        <div class="px-5 py-4 border-b border-zinc-800/60">
          <h2 class="text-sm font-bold text-zinc-200">Distribución de precios</h2>
          <p class="text-xs text-zinc-600 mt-0.5">Avisos por rango</p>
        </div>
        <div class="p-5 space-y-4">
          {datos.distribucion.map(d => (
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-xs font-medium text-zinc-400">{d.etiqueta}</span>
                <span class="text-xs tabular-nums text-zinc-500">
                  {d.total.toLocaleString('es-CL')}
                </span>
              </div>
              <div class="h-1.5 bg-zinc-800 rounded-full overflow-hidden">
                <div
                  class="h-full bg-amber-400/60 rounded-full"
                  style={`width: ${d.total > 0 ? (d.total / maxDist * 100).toFixed(1) : 0}%`}
                />
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Tabla de marcas: rango de precios -->
      <section class="bg-zinc-900 rounded-xl border border-zinc-800/60 overflow-hidden">
        <div class="px-5 py-4 border-b border-zinc-800/60">
          <h2 class="text-sm font-bold text-zinc-200">Rango de precios por marca</h2>
          <p class="text-xs text-zinc-600 mt-0.5">Mínimo y máximo publicados</p>
        </div>
        <div class="divide-y divide-zinc-800/40 max-h-96 overflow-y-auto">
          {datos.marcas.filter(m => m.precio_minimo && m.precio_maximo).map(m => (
            <div class="px-5 py-3">
              <div class="flex items-center justify-between mb-0.5">
                <span class="text-xs font-semibold text-zinc-300">{m.marca}</span>
                <span class="text-[10px] text-zinc-600 tabular-nums">{m.total} avisos</span>
              </div>
              <div class="flex items-center gap-1.5 text-[11px] tabular-nums">
                <span class="text-zinc-500">{formatearPrecio(Math.round(m.precio_minimo!))}</span>
                <span class="text-zinc-700 flex-1 border-t border-zinc-700 border-dashed mx-1" />
                <span class="text-zinc-500">{formatearPrecio(Math.round(m.precio_maximo!))}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

    </div>
  </div>

</Base>
