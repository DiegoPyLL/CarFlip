---
import Base from '@layouts/Base.astro';
import { resolverUrlImagen } from '@lib/cdn';
import { obtenerAviso } from '@lib/db';
import { formatearPrecio, formatearKm, formatearFecha, signosDelta } from '@lib/formato';

const { id } = Astro.params;
const idNum = parseInt(id ?? '');

if (isNaN(idNum)) return Astro.redirect('/404');

const aviso = await obtenerAviso(idNum);
if (!aviso) return Astro.redirect('/404');

const backRaw = Astro.url.searchParams.get('back') ?? '/';
const urlVolver = backRaw.startsWith('/') && !backRaw.startsWith('//') ? backRaw : '/';

const delta      = signosDelta(aviso.delta_pct);
const urlImagen  = resolverUrlImagen(aviso.url_imagen);
const titulo     = [aviso.marca, aviso.modelo, aviso.anio].filter(Boolean).join(' ') || aviso.titulo;
const descripcionPage = `${titulo} — ${aviso.precio ? formatearPrecio(aviso.precio, aviso.moneda) : 'Precio a consultar'}. ${aviso.km ? formatearKm(aviso.km) : ''} ${aviso.ubicacion ?? ''}`.trim();
const fuenteLabel = aviso.fuente === 'autocosmos' ? 'Autocosmos.cl' : 'Yapo.cl';

const ficha = [
  { label: 'Marca',       valor: aviso.marca },
  { label: 'Modelo',      valor: aviso.modelo },
  { label: 'Año',         valor: aviso.anio ? String(aviso.anio) : null },
  { label: 'Kilometraje', valor: aviso.km !== null ? formatearKm(aviso.km) : null },
  { label: 'Combustible', valor: aviso.combustible },
  { label: 'Ubicación',   valor: aviso.ubicacion },
].filter(f => f.valor);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Car',
  name: aviso.titulo,
  brand: aviso.marca ? { '@type': 'Brand', name: aviso.marca } : undefined,
  model: aviso.modelo ?? undefined,
  modelDate: aviso.anio ?? undefined,
  mileageFromOdometer: aviso.km ? { '@type': 'QuantitativeValue', value: aviso.km, unitCode: 'KMT' } : undefined,
  fuelType: aviso.combustible ?? undefined,
  offers: aviso.precio ? { '@type': 'Offer', price: aviso.precio, priceCurrency: aviso.moneda, url: aviso.url } : undefined,
  image: urlImagen ?? undefined,
  description: aviso.descripcion ?? undefined,
};
---

<Base
  titulo={`${titulo} — CarFlip`}
  descripcion={descripcionPage}
  urlCanonica={Astro.url.href}
  urlImagen={urlImagen ?? undefined}
  tipo="product"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="max-w-4xl mx-auto">

    <!-- Volver -->
    <a
      href={urlVolver}
      class="inline-flex items-center gap-1.5 text-sm text-zinc-600 hover:text-zinc-300 mb-5 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      Volver a avisos
    </a>

    <div class="bg-zinc-900 rounded-xl border border-zinc-800/60 overflow-hidden">

      <!-- Imagen -->
      {urlImagen ? (
        <div class="aspect-[16/9] bg-zinc-800">
          <img
            src={urlImagen}
            alt={aviso.titulo}
            width={900}
            height={506}
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover"
          />
        </div>
      ) : (
        <div class="aspect-[16/9] bg-zinc-800 flex items-center justify-center text-zinc-700 text-sm">
          Sin imagen
        </div>
      )}

      <div class="p-6 sm:p-8">

        <!-- Badges -->
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="text-xs font-semibold px-2.5 py-1 rounded bg-zinc-800 text-zinc-400 border border-zinc-700">
            {fuenteLabel}
          </span>
          {delta && (
            <span class={`text-xs font-semibold px-2.5 py-1 rounded ${delta.clases}`}>
              {delta.texto}
            </span>
          )}
          {aviso.disponible === false && (
            <span class="text-xs font-semibold px-2.5 py-1 rounded bg-red-950/60 text-red-400 border border-red-900/40">
              No disponible
            </span>
          )}
        </div>

        <!-- Título y precio -->
        <h1 class="text-xl sm:text-2xl font-bold text-zinc-100 leading-snug mb-4">
          {aviso.titulo}
        </h1>

        <div class="flex flex-wrap items-baseline gap-3 mb-6 pb-6 border-b border-zinc-800/60">
          <span class="text-3xl sm:text-4xl font-black text-amber-400 tabular-nums">
            {aviso.precio ? formatearPrecio(aviso.precio, aviso.moneda) : 'Precio a consultar'}
          </span>
          {aviso.precio_anterior && delta && (
            <span class="text-sm text-zinc-600 line-through tabular-nums">
              {formatearPrecio(aviso.precio_anterior, aviso.moneda)}
            </span>
          )}
        </div>

        <!-- Layout: ficha + CTA -->
        <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-8">

          <!-- Ficha técnica -->
          <dl class="grid grid-cols-2 gap-x-8 gap-y-4">
            {ficha.map(({ label, valor }) => (
              <div>
                <dt class="text-[10px] font-semibold text-zinc-600 uppercase tracking-wider mb-0.5">
                  {label}
                </dt>
                <dd class="text-sm font-semibold text-zinc-200">{valor}</dd>
              </div>
            ))}
          </dl>

          <!-- CTA + fechas -->
          <div class="flex flex-col gap-4 sm:items-end">
            <a
              href={aviso.url}
              rel="noopener noreferrer"
              target="_blank"
              class="inline-flex items-center gap-2 bg-amber-400 hover:bg-amber-300 text-zinc-900 text-sm font-bold px-6 py-3 rounded-xl transition-colors duration-150 shrink-0"
            >
              Ver aviso original
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>

            <div class="text-xs text-zinc-600 sm:text-right space-y-1">
              {aviso.primera_vez_visto && (
                <p>Visto por primera vez: <span class="text-zinc-500">{formatearFecha(aviso.primera_vez_visto)}</span></p>
              )}
              {aviso.ultima_vez_visto && (
                <p>Última actualización: <span class="text-zinc-500">{formatearFecha(aviso.ultima_vez_visto)}</span></p>
              )}
            </div>
          </div>
        </div>

        <!-- Descripción -->
        {aviso.descripcion && (
          <div class="mt-8 pt-6 border-t border-zinc-800/60">
            <h2 class="text-xs font-semibold text-zinc-600 uppercase tracking-wider mb-3">Descripción</h2>
            <p class="text-sm text-zinc-400 whitespace-pre-line leading-relaxed max-w-2xl">
              {aviso.descripcion}
            </p>
          </div>
        )}

      </div>
    </div>
  </div>
</Base>
