---
import Base from '@layouts/Base.astro';
import { resolverUrlImagen } from '@lib/cdn';
import { obtenerAviso } from '@lib/db';
import { formatearPrecio, formatearKm, formatearFecha, signosDelta } from '@lib/formato';

const { id } = Astro.params;
const idNum = parseInt(id ?? '');

if (isNaN(idNum)) {
  return Astro.redirect('/404');
}

const aviso = await obtenerAviso(idNum);
if (!aviso) {
  return Astro.redirect('/404');
}

const delta = signosDelta(aviso.delta_pct);
const urlImagen = resolverUrlImagen(aviso.url_imagen);
const titulo = [aviso.marca, aviso.modelo, aviso.anio].filter(Boolean).join(' ') || aviso.titulo;
const descripcionPage = `${titulo} — ${aviso.precio ? formatearPrecio(aviso.precio, aviso.moneda) : 'Precio a consultar'}. ${aviso.km ? formatearKm(aviso.km) : ''} ${aviso.ubicacion ?? ''}`.trim();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Car',
  name: aviso.titulo,
  brand: aviso.marca ? { '@type': 'Brand', name: aviso.marca } : undefined,
  model: aviso.modelo ?? undefined,
  modelDate: aviso.anio ?? undefined,
  mileageFromOdometer: aviso.km ? { '@type': 'QuantitativeValue', value: aviso.km, unitCode: 'KMT' } : undefined,
  fuelType: aviso.combustible ?? undefined,
  offers: aviso.precio ? {
    '@type': 'Offer',
    price: aviso.precio,
    priceCurrency: aviso.moneda,
    url: aviso.url,
  } : undefined,
  image: urlImagen ?? undefined,
  description: aviso.descripcion ?? undefined,
};
---

<Base
  titulo={`${titulo} — CarFlip`}
  descripcion={descripcionPage}
  urlCanonica={Astro.url.href}
  urlImagen={urlImagen ?? undefined}
  tipo="product"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="max-w-4xl mx-auto">
    <!-- Volver -->
    <a href="/" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-blue-700 mb-4 transition-colors">
      ← Volver a avisos
    </a>

    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
      <!-- Imagen LCP -->
      {urlImagen ? (
        <div class="aspect-[16/9] bg-gray-100">
          <img
            src={urlImagen}
            alt={aviso.titulo}
            width={900}
            height={506}
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover"
          />
        </div>
      ) : (
        <div class="aspect-[16/9] bg-gray-100 flex items-center justify-center text-gray-400">Sin imagen</div>
      )}

      <div class="p-6">
        <!-- Badges -->
        <div class="flex flex-wrap gap-2 mb-3">
          <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${aviso.fuente === 'autocosmos' ? 'bg-orange-100 text-orange-700' : 'bg-yellow-100 text-yellow-700'}`}>
            {aviso.fuente === 'autocosmos' ? 'Autocosmos' : 'MercadoLibre'}
          </span>
          {delta && (
            <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${delta.clases}`}>
              {delta.texto}
            </span>
          )}
          {aviso.disponible === false && (
            <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-red-100 text-red-700">No disponible</span>
          )}
        </div>

        <!-- Título y precio -->
        <h1 class="text-2xl font-bold text-gray-900 mb-1">{aviso.titulo}</h1>
        <p class="text-3xl font-bold text-blue-700 mb-1">
          {aviso.precio ? formatearPrecio(aviso.precio, aviso.moneda) : 'Precio a consultar'}
        </p>
        {aviso.precio_anterior && delta && (
          <p class="text-sm text-gray-500 mb-4">
            Precio anterior: {formatearPrecio(aviso.precio_anterior, aviso.moneda)}
          </p>
        )}

        <!-- Ficha técnica -->
        <dl class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-4 mt-6 border-t border-gray-100 pt-6">
          {aviso.marca && (
            <>
              <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Marca</dt>
              <dd class="text-sm font-semibold text-gray-900 col-span-1">{aviso.marca}</dd>
            </>
          )}
          {aviso.modelo && (
            <>
              <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Modelo</dt>
              <dd class="text-sm font-semibold text-gray-900">{aviso.modelo}</dd>
            </>
          )}
          {aviso.anio && (
            <>
              <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Año</dt>
              <dd class="text-sm font-semibold text-gray-900">{aviso.anio}</dd>
            </>
          )}
          {aviso.km !== null && (
            <>
              <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Kilometraje</dt>
              <dd class="text-sm font-semibold text-gray-900">{formatearKm(aviso.km)}</dd>
            </>
          )}
          {aviso.combustible && (
            <>
              <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Combustible</dt>
              <dd class="text-sm font-semibold text-gray-900">{aviso.combustible}</dd>
            </>
          )}
          {aviso.ubicacion && (
            <>
              <dt class="text-xs font-medium text-gray-500 uppercase tracking-wide">Ubicación</dt>
              <dd class="text-sm font-semibold text-gray-900">{aviso.ubicacion}</dd>
            </>
          )}
        </dl>

        <!-- Historial -->
        <div class="mt-6 border-t border-gray-100 pt-6 flex flex-wrap gap-6 text-sm text-gray-500">
          {aviso.primera_vez_visto && (
            <p>Visto por primera vez: <span class="font-medium text-gray-700">{formatearFecha(aviso.primera_vez_visto)}</span></p>
          )}
          {aviso.ultima_vez_visto && (
            <p>Última actualización: <span class="font-medium text-gray-700">{formatearFecha(aviso.ultima_vez_visto)}</span></p>
          )}
        </div>

        <!-- Descripción -->
        {aviso.descripcion && (
          <div class="mt-6 border-t border-gray-100 pt-6">
            <h2 class="text-sm font-semibold text-gray-700 mb-2">Descripción</h2>
            <p class="text-sm text-gray-600 whitespace-pre-line">{aviso.descripcion}</p>
          </div>
        )}

        <!-- CTA -->
        <div class="mt-8">
          <a
            href={aviso.url}
            rel="noopener noreferrer"
            target="_blank"
            class="inline-block bg-blue-700 text-white text-sm font-semibold px-6 py-3 rounded-xl hover:bg-blue-800 transition-colors"
          >
            Ver aviso original →
          </a>
        </div>
      </div>
    </div>
  </div>
</Base>
