---
interface Props {
  titulo: string;
  descripcion?: string;
  urlCanonica?: string;
  urlImagen?: string;
  tipo?: string;
}

const {
  titulo,
  descripcion = 'CarFlip — Encuentra oportunidades de autos en Chile. Comparamos precios de Autocosmos y Yapo en tiempo real.',
  urlCanonica = Astro.url.href,
  urlImagen = '/og-default.png',
  tipo = 'website',
} = Astro.props;

const tituloCompleto = titulo.endsWith('CarFlip') ? titulo : `${titulo} — CarFlip`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fbbf24" />

    <title>{tituloCompleto}</title>
    <meta name="description" content={descripcion} />
    <link rel="canonical" href={urlCanonica} />

    <!-- Open Graph -->
    <meta property="og:type" content={tipo} />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:image" content={urlImagen} />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content="CarFlip" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tituloCompleto} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={urlImagen} />

    <slot name="head" />
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen flex flex-col antialiased">
    <header class="sticky top-0 z-20 bg-zinc-950/90 backdrop-blur-md border-b border-zinc-800/60">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
          <span class="font-black text-xl tracking-tight text-amber-400">CarFlip</span>
          <span class="hidden sm:block text-xs text-zinc-600 font-medium">Comparador de autos Chile</span>
        </a>
        <nav aria-label="Navegación principal">
          <ul class="flex gap-5 text-sm font-medium text-zinc-500">
            <li>
              <a href="/" class="hover:text-zinc-200 transition-colors duration-150">Avisos</a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-6">
      <slot />
    </main>

    <footer class="border-t border-zinc-800/60 mt-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex items-center justify-between">
        <span class="text-xs text-zinc-600">&copy; {new Date().getFullYear()} CarFlip</span>
        <span class="text-xs text-zinc-700">Comparador de precios de autos en Chile</span>
      </div>
    </footer>
  </body>
</html>
